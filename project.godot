; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MusicScene — gscore_osc"
config/description="OSC-controlled INScore-inspired interactive music-score / world system."
run/main_scene="uid://bnc7tiusqtes3"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GScoreOSC="*uid://bi0bofnnp72f4"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/gscore_osc/plugin.cfg")

[gscore_osc]

space="3d"
network/listen_port=7400
network/send_host="127.0.0.1"
network/send_port=7401
network/autostart=true
app/coord_mode="normalized"
physics/coord_mode="normalized"
developer_mode=false
permissions/bind_existing=true
permissions/instantiate=true
permissions/call_methods=true
permissions/set_props=true
permissions/free_nodes=false
notation/external_renderer_path=""
notation/external_renderer_args=""
notation/engraver_output="png"
notation/engraver_output/mei="svg"
notation/engraver_output/abc="svg"
notation/engraver/musicxml="\"C:/Program Files/MuseScore 4/bin/MuseScore4.exe\" {input} -o {output} -T 10 -r 200"
notation/engraver/mei="py \"res://tools/verovio_render.py\" {input} {output} --page {page}"
notation/engraver/lilypond="\"C:/Program Files/lilypond-2.25.81/bin/lilypond.exe\" --png -dcrop=#t -dresolution=200 -o {outbase} {input}"
notation/engraver/abc="py \"res://tools/verovio_render.py\" {input} {output} --page {page}"
logging/verbose=true
